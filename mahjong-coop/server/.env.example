# Puerto en el que escucha el servidor
# Default: 3000
PORT=3000

# Orígenes CORS permitidos (separados por comas)
# Para desarrollo local:
# CLIENT_ORIGIN=http://localhost:5173,http://localhost:3000
# Para producción en Vercel (reemplazar con tu URL de Vercel):
# CLIENT_ORIGIN=https://tu-vercel-app.vercel.app
# O usar CORS_ORIGIN como alias:
CLIENT_ORIGIN=http://localhost:5173

# Alias alternativo para CLIENT_ORIGIN
# CORS_ORIGIN=http://localhost:5173
