{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and statistics",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "totalWins": { "type": "number" },
        "totalScore": { "type": "number" }
      },
      "required": ["uid", "displayName"]
    },
    "Game": {
      "title": "Game",
      "description": "Mahjong game session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "status": { "type": "string", "enum": ["waiting", "playing", "finished"] },
        "hostId": { "type": "string" },
        "players": { "type": "array" },
        "currentTurnIndex": { "type": "number" },
        "tiles": { "type": "array" },
        "history": { "type": "array" },
        "startTime": { "type": "number" },
        "scores": { "type": "object" },
        "scoreHistory": { "type": "array" },
        "messages": { "type": "array" }
      },
      "required": ["code", "status", "hostId", "players", "messages"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User private data"
    },
    "/games/{gameId}": {
      "schema": "Game",
      "description": "Active game sessions"
    }
  }
}
